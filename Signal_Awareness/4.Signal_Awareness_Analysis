import numpy as np
import os
import glob
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches

# ── Configuration ─────────────────────────────────────────────────────────────
TRIPS = ["Day 1", "Day 2", "Day 3", "Day 4", "Day 5", "Day 6", "Day 7"]

# Mapping from day label to actual folder prefix (numeric trip ID)
TRIP_DIR_MAP = {
    "Day 1": "224",
    "Day 2": "230",
    "Day 3": "251",
    "Day 4": "253",
    "Day 5": "263",
    "Day 6": "265",
    "Day 7": "267",
}
OUTPUT_DIR = "signal_awareness_results"
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Right-turn intersections: red-on-right is legal when safe
RIGHT_TURN_INTERSECTIONS = {'Intersection_1', 'Intersection_3'}
LEFT_TURN_INTERSECTIONS  = {'Intersection_6'}

# Signal phase classification
SIGNAL_MAP = {
    "stop-And-Remain":             "RED",
    "permissive-Movement-Allowed": "GREEN",
    "protected-Movement-Allowed":  "GREEN",
    "permissive-clearance":        "YELLOW",
    "protected-clearance":         "YELLOW",
}

# ── Helpers ───────────────────────────────────────────────────────────────────
def classify_signal(status):
    return SIGNAL_MAP.get(str(status).strip(), "UNKNOWN")


def clean_numeric(series):
    # Strip Excel-escaped numeric strings (=""7.62..."") and convert to float.
    if series.dtype == object:
        cleaned = (series.astype(str)
                   .str.replace(r'^=*"+', '', regex=True)
                   .str.replace(r'"+$',  '', regex=True))
        return pd.to_numeric(cleaned, errors='coerce')
    return pd.to_numeric(series, errors='coerce')


def smean(df, col):
    v = df[col].dropna()
    return round(float(v.mean()), 4) if len(v) > 0 else np.nan


def haversine_m(lat1, lon1, lat2, lon2):
    """Great-circle distance in metres between two GPS points."""
    R = 6_371_000.0
    phi1, phi2   = np.radians(lat1), np.radians(lat2)
    dphi         = np.radians(lat2 - lat1)
    dlambda      = np.radians(lon2 - lon1)
    a = np.sin(dphi/2)**2 + np.cos(phi1)*np.cos(phi2)*np.sin(dlambda/2)**2
    return R * 2 * np.arctan2(np.sqrt(a), np.sqrt(1 - a))


# ── Loaders ───────────────────────────────────────────────────────────────────
def load_vehicle(path):
    df = pd.read_csv(path)
    df['Time']             = pd.to_datetime(df['Time'], format='ISO8601')
    df['Speed']            = clean_numeric(df['Speed'])
    df['accel']            = clean_numeric(df['accel'])
    df['Latitude']         = clean_numeric(df['Latitude'])
    df['Longitude']        = clean_numeric(df['Longitude'])
    df['FrontLat']         = clean_numeric(df['FrontLat'])
    df['FrontLong']        = clean_numeric(df['FrontLong'])
    df['isBrakeCmdActive'] = (df['isBrakeCmdActive'].astype(str)
                              .str.strip().str.lower()
                              .map({'true': True, 'false': False}))
    df['TTC']              = pd.to_numeric(df['TTC'], errors='coerce')
    df['TTC']              = df['TTC'].replace(99999.0, np.nan)   # 99999 = no lead vehicle
    df['RelativeDistance'] = pd.to_numeric(df['RelativeDistance'], errors='coerce')
    return df


def load_spat(path):
    df = pd.read_csv(path)
    df['Timestamp']   = pd.to_datetime(df['Timestamp'], format='ISO8601')
    df['SignalState'] = df['Status'].apply(classify_signal)
    return df


# ── Merge vehicle frames with nearest SPaT signal ────────────────────────────
def merge_vehicle_spat(veh_df, spat_df, inter):
    v = (veh_df[veh_df['Intersection_Group'] == inter]
         .copy().sort_values('Time').reset_index(drop=True))
    s = (spat_df[spat_df['Intersection_Group'] == inter]
         .copy().sort_values('Timestamp').reset_index(drop=True))
    if v.empty or s.empty:
        return pd.DataFrame()
    merged = pd.merge_asof(
        v,
        s[['Timestamp', 'Status', 'SignalState']],
        left_on='Time', right_on='Timestamp',
        direction='nearest',
        tolerance=pd.Timedelta('1s')
    )
    return merged.dropna(subset=['SignalState'])


# ── Signal phase transition response ─────────────────────────────────────────
def transition_metrics(merged):
    # GREEN->RED : how quickly (seconds) does vehicle start braking after signal turns red?
    # RED->GREEN : how quickly (seconds) does vehicle start moving after green onset?
    if len(merged) < 5:
        return {}

    df = merged.sort_values('Time').reset_index(drop=True)
    df['prev_state'] = df['SignalState'].shift(1)
    trans = df[(df['SignalState'] != df['prev_state']) & df['prev_state'].notna()]

    WINDOW = pd.Timedelta('5s')
    g2r_delays, r2g_delays = [], []

    for _, row in trans.iterrows():
        t = row['Time']
        window = df[(df['Time'] >= t) & (df['Time'] <= t + WINDOW)]

        if row['SignalState'] == 'RED':                          # GREEN → RED
            first_brake = window[window['isBrakeCmdActive'] == True]
            if not first_brake.empty:
                g2r_delays.append((first_brake.iloc[0]['Time'] - t).total_seconds())

        elif row['SignalState'] == 'GREEN' and row['prev_state'] == 'RED':  # RED → GREEN
            first_move = window[window['Speed'] > 1.0]
            if not first_move.empty:
                r2g_delays.append((first_move.iloc[0]['Time'] - t).total_seconds())

    return {
        'N_G2R_transitions':       len(trans[trans['SignalState'] == 'RED']),
        'N_R2G_transitions':       len(trans[(trans['SignalState'] == 'GREEN') &
                                              (trans['prev_state'] == 'RED')]),
        'Brake_delay_G2R_mean_s':  round(np.mean(g2r_delays), 3) if g2r_delays else np.nan,
        'Move_delay_R2G_mean_s':   round(np.mean(r2g_delays), 3) if r2g_delays else np.nan,
    }


# ── Stop-line crossing detection ──────────────────────────────────────────────
def detect_stop_line_crossing(merged):
    """
    Detect stop-line crossing using vehicle FRONT GPS (FrontLat/FrontLong).
    Legally, the front of the vehicle crossing the stop line determines
    whether the maneuver is committed.

    Method:
      1. Find the center-GPS crossing frame (StopLine_ID: non-null → null).
         The center GPS at that frame approximates the stop line location.
      2. For all frames up to the center crossing, compute the distance from
         FrontLat/FrontLong to that stop-line position.  The frame with the
         minimum distance is when the vehicle FRONT was at the stop line.
      3. Return that frame index and its signal state.

    Falls back to center-GPS crossing if front GPS is unavailable.

    Returns (cross_idx, cross_signal, method)
    """
    m = merged.reset_index(drop=True)
    m['_has_sl'] = m['StopLine_ID'].notna()

    # Step 1 – find center-GPS crossing index
    center_idx = None
    for i in range(1, len(m)):
        if m.loc[i-1, '_has_sl'] and not m.loc[i, '_has_sl']:
            center_idx = i
            break
    if center_idx is None:
        return None, None, None, None

    # Step 2 – front-GPS crossing
    if ('FrontLat' in m.columns and 'FrontLong' in m.columns
            and m['FrontLat'].notna().any()):
        # Stop-line position ≈ center GPS at the crossing frame
        sl_lat = m.loc[center_idx, 'Latitude']
        sl_lon = m.loc[center_idx, 'Longitude']

        if pd.notna(sl_lat) and pd.notna(sl_lon):
            pre = m.iloc[:center_idx + 1].copy()
            pre['_front_dist'] = pre.apply(
                lambda r: haversine_m(r['FrontLat'], r['FrontLong'], sl_lat, sl_lon)
                if pd.notna(r['FrontLat']) and pd.notna(r['FrontLong']) else np.nan,
                axis=1
            )
            pre = pre.dropna(subset=['_front_dist'])
            if not pre.empty:
                front_idx = int(pre['_front_dist'].idxmin())
                return (front_idx,
                        m.loc[front_idx, 'SignalState'],
                        'front_GPS',
                        m.loc[front_idx, 'Time'])

    # Fallback – center GPS
    return (center_idx,
            m.loc[center_idx, 'SignalState'],
            'center_GPS',
            m.loc[center_idx, 'Time'])


# ── SPaT RED onset detection ──────────────────────────────────────────────────
def find_red_onset_time(merged, near_time, window=pd.Timedelta('10s')):
    """
    Return the SPaT Timestamp of the RED onset nearest to near_time.
    Uses the 'Timestamp' column (SPaT message time) from the merged df.
    """
    df = merged.sort_values('Time').reset_index(drop=True)
    df['_prev'] = df['SignalState'].shift(1)
    onsets = df[(df['SignalState'] == 'RED') & (df['_prev'] != 'RED') & df['Timestamp'].notna()]
    onsets = onsets[abs(onsets['Time'] - near_time) <= window]
    if onsets.empty:
        # fallback: first RED frame Timestamp
        red = df[df['SignalState'] == 'RED']
        return red.iloc[0]['Timestamp'] if not red.empty else None
    idx = (onsets['Time'] - near_time).abs().idxmin()
    return onsets.loc[idx, 'Timestamp']


# ── Per-intersection metrics ──────────────────────────────────────────────────
def compute_metrics(merged, trip, inter, filename, veh_df=None):
    is_right_turn = inter in RIGHT_TURN_INTERSECTIONS

    # ── Classify frames by stop-line position ─────────────────────────────────
    cross_idx, cross_signal, cross_method, cross_time = detect_stop_line_crossing(merged)
    merged = merged.reset_index(drop=True)

    if cross_idx is not None:
        before_line = merged.iloc[:cross_idx]   # approaching stop line
        after_line  = merged.iloc[cross_idx:]   # inside / past intersection
    else:
        before_line = merged
        after_line  = pd.DataFrame(columns=merged.columns)

    # Detect data gap before crossing frame (makes signal assignment unreliable)
    if cross_idx is not None and cross_idx > 0:
        time_gap_s = (merged.loc[cross_idx, 'Time'] - merged.loc[cross_idx - 1, 'Time']).total_seconds()
        has_data_gap = time_gap_s > 2.0
    else:
        has_data_gap = False

    # Determine violation type
    cross_delta_s = np.nan   # front crossing time minus SPaT RED onset (seconds)
    if cross_signal in ('GREEN', 'YELLOW'):
        in_intersection_before_red = len(after_line) > 0
        violation_type = 'IN_INTERSECTION_BEFORE_RED' if in_intersection_before_red else 'OK'
    elif cross_signal == 'RED':
        in_intersection_before_red = False
        if is_right_turn:
            violation_type = 'LEGAL_RIGHT_ON_RED'
        elif has_data_gap:
            # Large time gap before crossing: matched SPaT signal is unreliable
            violation_type = 'DATA_GAP_INCONCLUSIVE'
        else:
            red_onset = find_red_onset_time(merged, cross_time) if cross_time is not None else None
            if red_onset is not None and cross_time is not None:
                cross_delta_s = round((cross_time - red_onset).total_seconds(), 3)
                violation_type = ('COMPLIANT'    if abs(cross_delta_s) <= 1.0
                                  else 'TRUE_VIOLATION')
            else:
                violation_type = 'TRUE_VIOLATION'
    else:
        in_intersection_before_red = False
        violation_type = 'OK'

    red    = merged[merged['SignalState'] == 'RED']
    green  = merged[merged['SignalState'] == 'GREEN']
    yellow = merged[merged['SignalState'] == 'YELLOW']

    # Red frames that require awareness = only those BEFORE stop-line crossing
    # (frames after crossing during G/Y are legal clearance, not a violation)
    if in_intersection_before_red:
        red_for_awareness = before_line[before_line['SignalState'] == 'RED']
    else:
        red_for_awareness = red

    if is_right_turn:
        # Right-turn-on-red: awareness = slowing down OR brake active OR stopped
        awareness = (
            ((red_for_awareness['accel'] < 0.0) |
             (red_for_awareness['isBrakeCmdActive'] == True)).mean()
            if len(red_for_awareness) > 0 else np.nan
        )
        # Right-turn stop compliance: vehicle must come to a full stop before
        # proceeding on RED (stop-and-check rule).
        #   NaN : no valid assessment possible (no cross detected, or green arrived first)
        #   1.0 : vehicle stopped (< 1 m/s) before proceeding
        #   0.0 : vehicle never stopped — genuine rolling right-on-red
        if cross_idx is None:
            # Stop-line position unknown; cannot assess stop compliance
            stop_comp = np.nan
        elif cross_signal in ('GREEN', 'YELLOW'):
            # Signal turned green before vehicle reached the line;
            # same as DECELERATING_LEGAL for straight — stop not required
            stop_comp = np.nan
        else:
            # cross_signal == 'RED': genuine right-on-red maneuver
            _rbc_rt = before_line[before_line['SignalState'] == 'RED']
            if len(_rbc_rt) == 0:
                stop_comp = np.nan
            else:
                _min_v_rt = float(_rbc_rt['Speed'].min())
                if _min_v_rt < 1.0:
                    stop_comp = 1.0
                else:
                    # Not stopped inside zone; look back up to 30 s before zone
                    # entry to catch vehicles that stopped outside the region.
                    _stopped_pre = False
                    if veh_df is not None and len(merged) > 0:
                        entry_time = merged['Time'].iloc[0]
                        lookback = veh_df[
                            (veh_df['Time'] >= entry_time - pd.Timedelta('30s')) &
                            (veh_df['Time'] <  entry_time)
                        ]
                        if len(lookback) > 0 and float(lookback['Speed'].min()) < 1.0:
                            _stopped_pre = True
                    stop_comp = 1.0 if _stopped_pre else 0.0
    else:
        awareness = (
            ((red_for_awareness['accel'] < 0.05) |
             (red_for_awareness['isBrakeCmdActive'] == True)|
             (red_for_awareness['Speed'] < 0.08)).mean()
            if len(red_for_awareness) > 0 else np.nan
        )      
        # Stop compliance: binary — did the vehicle come to a stop (any frame Speed < 1 m/s)
        # before the stop line during RED?
        #   1.0 = yes (compliant, regardless of how many frames were stopped)
        #   0.0 = no  (never stopped before the line during RED)
        #   NaN = not applicable (signal turned green before vehicle reached stop line)
        _rbc = before_line[before_line['SignalState'] == 'RED']
        if len(_rbc) == 0:
            stop_comp = np.nan
        else:
            _min_v  = float(_rbc['Speed'].min())
            _accel  = float(_rbc['accel'].mean()) if _rbc['accel'].notna().any() else np.nan
            _compliant_vtype = violation_type in (
                'OK', 'IN_INTERSECTION_BEFORE_RED', 'LEGAL_RIGHT_ON_RED',
                'COMPLIANT', 'DATA_GAP_INCONCLUSIVE'
            )
            # DECELERATING_LEGAL: never slowed below 2.0 m/s + compliant type + decelerating
            _legal_nonstop = (
                _min_v > 2.0 and _compliant_vtype
                and (np.isnan(_accel) or _accel < 0)
            )
            if _legal_nonstop:
                stop_comp = np.nan        # no stop required (green came first)
            elif _min_v < 0.5:
                stop_comp = 1.0           # stopped at least once before line on RED
            else:
                stop_comp = 0.0           # never reached below 0.5 m/s

    # Speed contrast between signal states
    spd_g = smean(green, 'Speed')
    spd_r = smean(red,   'Speed')
    spd_delta = (round(spd_g - spd_r, 4)
                 if not (np.isnan(spd_g) or np.isnan(spd_r)) else np.nan)

    # TTC only when a lead vehicle is present
    red_ttc   = red[red['TTC'].notna()]
    green_ttc = green[green['TTC'].notna()]

    # ── Stop-line behavior: did vehicle stop behind the line on RED? ───────────
    # Use front-GPS cross_idx: before_line = all frames where vehicle FRONT
    # has not yet reached the stop line (already computed by detect_stop_line_crossing).
    # This is more accurate than StopLine_ID (center GPS) because legally the
    # front of the vehicle determines whether it has passed the stop line.
    red_before_cross = before_line[before_line['SignalState'] == 'RED']
    if len(red_before_cross) == 0:
        # No RED frames before front crossed the line (crossed on GREEN/YELLOW)
        stop_line_behavior  = 'NO_RED_BEFORE_CROSS'
        min_spd_stopzone    = np.nan
    else:
        min_spd_stopzone = round(float(red_before_cross['Speed'].min()), 3)
        if min_spd_stopzone <= 0.5:
            stop_line_behavior = 'STOP_BEHIND'    # fully stopped behind line
        elif min_spd_stopzone <= 3.0:
            stop_line_behavior = 'SLOW_ROLL'      # crept through slowly (e.g. right-turn)
        else:
            # Speed > 3 m/s during RED before crossing.
            # If vehicle was decelerating (mean accel < 0) AND no violation was flagged,
            # the vehicle was legally approaching while the signal changed to green
            # before it reached the stop line — classify as compliant approach.
            accel_red_approach = (red_before_cross['accel'].mean()
                                  if red_before_cross['accel'].notna().any() else np.nan)
            compliant_vtype = violation_type in ('OK', 'IN_INTERSECTION_BEFORE_RED',
                                                 'LEGAL_RIGHT_ON_RED', 'COMPLIANT',
                                                 'DATA_GAP_INCONCLUSIVE')
            if compliant_vtype and (np.isnan(accel_red_approach) or accel_red_approach < 0):
                stop_line_behavior = 'DECELERATING_LEGAL'  # decelerating, signal turned green first
            else:
                stop_line_behavior = 'DID_NOT_STOP'        # ran red without braking

    trans = transition_metrics(merged)

    return {
        'Trip':               trip,
        'File':               filename,
        'Intersection':       inter,
        'Is_Right_Turn':      is_right_turn,
        # Stop-line crossing context
        'Cross_Signal':       cross_signal if cross_signal else 'NO_CROSS',
        'Cross_Method':       cross_method if cross_method else 'NO_CROSS',
        'Violation_Type':     violation_type,
        'Cross_Delta_s':      cross_delta_s,   # front crossing minus SPaT RED onset (s)
        'In_Intersection_Before_Red': in_intersection_before_red,
        'Red_frames_for_awareness':   len(red_for_awareness),
        # Stop-line behavior
        'Stop_Line_Behavior':         stop_line_behavior,
        'Min_Speed_Stopzone_RED':     min_spd_stopzone,
        # Frame counts
        'Total_frames':       len(merged),
        'Red_frames':         len(red),
        'Green_frames':       len(green),
        'Yellow_frames':      len(yellow),
        # Speed by phase
        'Speed_mean_all':     smean(merged, 'Speed'),
        'Speed_mean_RED':     spd_r,
        'Speed_mean_GREEN':   spd_g,
        'Speed_mean_YELLOW':  smean(yellow, 'Speed'),
        'Speed_delta_G_R':    spd_delta,
        # Acceleration by phase (real accel column)
        'Accel_mean_RED':     smean(red,    'accel'),
        'Accel_mean_GREEN':   smean(green,  'accel'),
        'Accel_mean_YELLOW':  smean(yellow, 'accel'),
        # Brake activation rate
        'Brake_rate_RED':     round(red['isBrakeCmdActive'].mean(),   4) if len(red)   > 0 else np.nan,
        'Brake_rate_GREEN':   round(green['isBrakeCmdActive'].mean(), 4) if len(green) > 0 else np.nan,
        # Core awareness metrics
        'Awareness_rate_RED': round(awareness, 4) if not np.isnan(awareness) else np.nan,
        'Stop_compliance_RED':round(stop_comp, 4) if not np.isnan(stop_comp) else np.nan,
        # TTC (lead vehicle present)
        'TTC_mean_RED':       smean(red_ttc,   'TTC'),
        'TTC_mean_GREEN':     smean(green_ttc, 'TTC'),
        # Phase-transition response delays
        **trans,
    }


# ── Main ──────────────────────────────────────────────────────────────────────
all_metrics = []
all_traces  = []   # raw per-encounter traces for trajectory plots

for trip in TRIPS:
    trip_id  = TRIP_DIR_MAP[trip]
    veh_dir  = f"{trip_id}_signal_only_intersection_data_no_object"
    spat_dir = f"{trip_id}_spat_data"

    if not os.path.isdir(veh_dir) or not os.path.isdir(spat_dir):
        print(f"[SKIP] Trip {trip}: directories missing")
        continue

    # Build stem → spat_path lookup
    spat_lookup = {
        os.path.basename(p).replace("_spat.csv", ""): p
        for p in glob.glob(os.path.join(spat_dir, "*.csv"))
    }

    veh_files = sorted(glob.glob(os.path.join(veh_dir, "*.csv")))
    print(f"\n=== Trip {trip} (ID: {trip_id})  ({len(veh_files)} files) ===")

    for veh_path in veh_files:
        filename = os.path.basename(veh_path)
        stem     = os.path.splitext(filename)[0]
        spat_path = spat_lookup.get(stem)
        if spat_path is None:
            print(f"  [SKIP] {filename}: no matching SPaT file")
            continue

        veh_df  = load_vehicle(veh_path)
        spat_df = load_spat(spat_path)

        intersections = sorted(
            [g for g in veh_df['Intersection_Group'].unique()
             if isinstance(g, str) and g.startswith('Intersection_')],
            key=lambda x: int(x.split('_')[1])
        )

        for inter in intersections:
            merged = merge_vehicle_spat(veh_df, spat_df, inter)
            if merged.empty or merged['SignalState'].eq('UNKNOWN').all():
                continue

            m = compute_metrics(merged, trip, inter, filename, veh_df=veh_df)
            all_metrics.append(m)

            # Save raw frame-level trace for within-encounter trajectory analysis
            t0 = merged['Time'].iloc[0]
            all_traces.append({
                'trip':         trip,
                'intersection': inter,
                't_s':          (merged['Time'] - t0).dt.total_seconds().values,
                'accel':        merged['accel'].values.astype(float),
                'speed':        merged['Speed'].values.astype(float),
                'signal':       merged['SignalState'].values,
            })

            print(f"  {filename:<50s} {inter}: "
                  f"R={m['Red_frames']:>4d}frm  "
                  f"awareness={m['Awareness_rate_RED']!s:>6}  "
                  f"stop_comp={m['Stop_compliance_RED']!s:>6}  "
                  f"spd_R={m['Speed_mean_RED']!s:>7} m/s  "
                  f"Δspd={m['Speed_delta_G_R']!s:>7}")


# ── Save outputs ──────────────────────────────────────────────────────────────
if not all_metrics:
    print("\nNo results produced — check that input directories exist.")
else:
    detail_df = pd.DataFrame(all_metrics)

    METRIC_COLS = [
        'Awareness_rate_RED', 'Stop_compliance_RED', 'Brake_rate_RED',
        'Speed_mean_RED', 'Speed_mean_GREEN', 'Speed_delta_G_R',
        'Accel_mean_RED', 'Accel_mean_GREEN', 'Accel_mean_YELLOW',
        'TTC_mean_RED', 'TTC_mean_GREEN',
        'Brake_delay_G2R_mean_s', 'Move_delay_R2G_mean_s',
    ]

    detail_df.to_csv(os.path.join(OUTPUT_DIR, "awareness_detail.csv"), index=False)

    agg_trip = (detail_df.groupby('Trip')[METRIC_COLS]
                .mean().round(4).reset_index())
    agg_trip.to_csv(os.path.join(OUTPUT_DIR, "awareness_by_trip.csv"), index=False)

    agg_inter = (detail_df.groupby('Intersection')[METRIC_COLS]
                 .mean().round(4).reset_index())
    agg_inter.to_csv(os.path.join(OUTPUT_DIR, "awareness_by_intersection.csv"), index=False)

    agg_trip_inter = (detail_df.groupby(['Trip', 'Intersection'])[METRIC_COLS]
                      .mean().round(4).reset_index())
    agg_trip_inter.to_csv(os.path.join(OUTPUT_DIR, "awareness_by_trip_intersection.csv"), index=False)

    print(f"\n{'─'*70}")
    print(f"Saved {len(detail_df)} rows → {OUTPUT_DIR}/")
    print(f"  awareness_detail.csv")
    print(f"  awareness_by_trip.csv")
    print(f"  awareness_by_intersection.csv")
    print(f"  awareness_by_trip_intersection.csv")

    # ── Console summary ───────────────────────────────────────────────────────
    summary_cols = ['Awareness_rate_RED', 'Stop_compliance_RED',
                    'Speed_mean_RED', 'Speed_delta_G_R',
                    'Brake_delay_G2R_mean_s', 'Move_delay_R2G_mean_s']

    print(f"\n{'═'*70}")
    print("SUMMARY BY TRIP")
    print('═'*70)
