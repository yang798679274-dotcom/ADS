    # ── Fig 9a & 9b: Speed / Acceleration trajectory per intersection ────────
    # Each trace = one encounter (entry → exit), time normalized to [0, 1].
    TRIP_COLORS = {t: c for t, c in zip(
        trips_sorted,
        ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728',
         '#9467bd', '#8c564b', '#e377c2']
    )}
    t_grid = np.linspace(0, 1, 200)
    ncols  = 4
    nrows  = (len(inters_sorted) + ncols - 1) // ncols

    def _draw_trajectory_panel(fig, field, ylabel, zero_line=False, ylim_zero=False):
        axes = np.array(fig.subplots(nrows, ncols, sharey=False)).flatten()
        legend_handles = {}

        for ax_idx, inter in enumerate(inters_sorted):
            ax = axes[ax_idx]
            inter_traces = [tr for tr in all_traces if tr['intersection'] == inter]

            interp_matrix = []
            for tr in inter_traces:
                t_s  = tr['t_s']
                vals = tr[field]
                valid = ~np.isnan(vals)
                if valid.sum() < 3:
                    continue
                t_v, v_v = t_s[valid], vals[valid]
                duration = t_v[-1] - t_v[0]
                if duration <= 0:
                    continue
                t_norm   = (t_v - t_v[0]) / duration
                v_interp = np.interp(t_grid, t_norm, v_v)
                interp_matrix.append(v_interp)

                color = TRIP_COLORS.get(tr['trip'], 'gray')
                ln, = ax.plot(t_grid, v_interp, color=color,
                              alpha=0.45, linewidth=1.2)
                legend_handles[tr['trip']] = ln

            if interp_matrix:
                mat    = np.array(interp_matrix)
                mean_v = np.nanmean(mat, axis=0)
                std_v  = np.nanstd(mat,  axis=0)
                ax.plot(t_grid, mean_v, color='black', linewidth=2.5, zorder=5)
                ax.fill_between(t_grid, mean_v - std_v, mean_v + std_v,
                                color='black', alpha=0.12, zorder=4)

            if zero_line:
                ax.axhline(0, color='gray', lw=0.8, ls='--', alpha=0.7)
            if ylim_zero:
                ax.set_ylim(bottom=0)

            short = inter.replace('Intersection_', 'Intersection ')
            if inter in RIGHT_TURN_INTERSECTIONS:
                turn_mark   = '  [Right-turn]'
                title_color = '#7b2c9e'
                ax.set_facecolor('#fdf6ff')
            elif inter in LEFT_TURN_INTERSECTIONS:
                turn_mark   = '  [Left-turn]'
                title_color = '#1a6e2e'
                ax.set_facecolor('#f0fff4')
            else:
                turn_mark   = '  [Straight]'
                title_color = '#1f4e79'
                ax.set_facecolor('#f0f6ff')
            ax.set_title(f'{short}{turn_mark}', fontsize=11, color=title_color)
            ax.set_xlabel('Normalized Time (entry → exit)', fontsize=9)
            if ax_idx % ncols == 0:
                ax.set_ylabel(ylabel, fontsize=9)
            ax.annotate(f'n={len(interp_matrix)} encounters',
                        xy=(0.03, 0.04), xycoords='axes fraction',
                        fontsize=8, color='gray')

        for ax_idx in range(len(inters_sorted), len(axes)):
            axes[ax_idx].set_visible(False)

        mean_patch = plt.Line2D([0], [0], color='black', linewidth=2.5)
        day_handles = [legend_handles[t] for t in trips_sorted if t in legend_handles]
        day_labels  = [t for t in trips_sorted if t in legend_handles]
        fig.legend(
            [mean_patch] + day_handles,
            ['Mean ± 1SD'] + day_labels,
            title='Encounter', loc='lower right',
            fontsize=9, ncol=2, framealpha=0.9
        )
    fig9a = plt.figure(figsize=(ncols * 5, nrows * 4 + 1))
    _draw_trajectory_panel(fig9a, 'speed', 'Speed (m/s)',
                           zero_line=False, ylim_zero=True)
